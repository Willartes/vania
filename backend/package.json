{
  "name": "lumiere-clinic-backend",
  "version": "1.0.0",
  "description": "Backend da Lumi\u00e8re Clinic - API REST com Node.js + Express + SQLite",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/database/seed.js",
    "dev:3001": "PORT=3001 nodemon src/server.js",
    "kill-port": "kill $(lsof -ti:3000) 2>/dev/null || true",
    "fresh": "npm run kill-port && npm run dev"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}